}
em {
  font-style: normal;
}
sup,
sub {
  height: 0;
  line-height: 0;
  font-size: 10px;
}
sup {
  vertical-align: super;
}
sub {
  vertical-align: sub;
}
.tpl_clr:before,
.tpl_clr:after {
  content: " ";
  display: table;
}
.tpl_clr:after {
  clear: both;
}
.tpl_clr {
  *zoom: 1;
}
